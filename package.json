{
  "name": "supreme-visual-effects",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/supreme-visual-effects.cjs",
  "module": "./dist/supreme-visual-effects.js",
  "exports": {
    ".": {
      "import": "./dist/supreme-visual-effects.js",
      "require": "./dist/supreme-visual-effects.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "release": "changeset publish",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix --config .eslintrc.cjs",
    "format": "prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "precommit": "lint-staged",
    "build:lib": "rollup -c"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.3.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.1.2",
    "@typescript-eslint/parser": "^7.1.2",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitest/coverage-v8": "^1.4.0",
    "@vue/test-utils": "^2.4.2",
    "c8": "^8.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.24.0",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.3.1",
    "rollup": "^4.16.2",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-vue": "^6.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "vitepress": "^1.2.0",
    "vitest": "^1.4.0",
    "vue": "^3.4.27",
    "vue-eslint-parser": "^10.2.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "effects",
    "visual-effects"
  ],
  "author": "Jaya",
  "license": "MIT"
}
