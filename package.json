{
  "name": "supreme-visual-effects",
  "version": "0.0.1",
  "description": "A Vue 3 visual effects component library with 18+ GPU-accelerated components",
  "type": "module",
  "main": "./dist/supreme-visual-effects.cjs.js",
  "module": "./dist/supreme-visual-effects.mjs.js",
  "types": "./dist/supreme-visual-effects.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/supreme-visual-effects.d.ts",
        "default": "./dist/supreme-visual-effects.mjs.js"
      },
      "require": {
        "types": "./dist/supreme-visual-effects.d.ts",
        "default": "./dist/supreme-visual-effects.cjs.js"
      }
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/jiayuexin/supreme-visual-effects",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiayuexin/supreme-visual-effects.git"
  },
  "bugs": {
    "url": "https://github.com/jiayuexin/supreme-visual-effects/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "effects",
    "visual-effects",
    "animation",
    "transition",
    "components",
    "ui",
    "typescript"
  ],
  "author": "Jaya",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "release": "changeset publish",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix --config .eslintrc.cjs",
    "format": "prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.3.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.1.2",
    "@typescript-eslint/parser": "^7.1.2",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitest/coverage-v8": "^1.4.0",
    "@vue/runtime-dom": "^3.5.22",
    "@vue/test-utils": "^2.4.2",
    "c8": "^8.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.24.0",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.3.1",
    "rollup": "^4.16.2",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-vue": "^6.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.4.6",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.2.0",
    "vitest": "^1.4.0",
    "vue": "^3.5.22",
    "vue-eslint-parser": "^10.2.0"
  }
}
